# CoHabit-AI — Environment Configuration Template
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.

# ── Environment ────────────────────────────────────────────────────
# "development" (CORS allows all) or "production" (CORS locked to FRONTEND_URL)
ENV=development

# ── PostgreSQL Database ────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cohabit-ai_DB
DB_USER=postgres
DB_PASSWORD=your_db_password_here

# ── JWT Authentication ─────────────────────────────────────────────
# REQUIRED in production: use a long, random string (e.g. openssl rand -hex 32)
JWT_SECRET=CHANGE_ME_TO_A_STRONG_RANDOM_SECRET
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Google Gemini AI ───────────────────────────────────────────────
# REQUIRED: Get your key at https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# ── CORS ───────────────────────────────────────────────────────────
# In production, set this to your frontend domain(s), comma-separated
# Example: https://app.cohabit.ai,https://www.cohabit.ai
FRONTEND_URL=http://localhost:3000
